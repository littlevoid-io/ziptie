{
  "hooks": {
    "after:bump": "npm run package && powershell -Command \"Compress-Archive -Path dist/ziptie.exe, scripts, ziptie.default.config.json, ziptie-schema.json, setup.bat -DestinationPath dist/ziptie.zip -Force\""
  },
  "git": {
    "requireBranch": "main",
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "push": true,
    "changelog": "git log --pretty=format:\"* %s (%h)\" \"${from}...${to}\""
  },
  "github": {
    "release": true,
    "releaseName": "Ziptie Release v${version}",
    "draft": false,
    "assets": ["dist/ziptie.zip"],
    "changelog": "git log --pretty=format:\"* %s (%h)\" \"${from}...${to}\""
  },
  "npm": {
    "publish": false
  }
}
