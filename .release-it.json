{
  "hooks": {
    "after:bump": "npm run package && powershell -Command \"Compress-Archive -Path dist/slab.exe, scripts, slab.default.config.json, slab-schema.json, setup.bat -DestinationPath dist/slab.zip -Force\""
  },
  "git": {
    "requireBranch": "main",
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "push": true,
    "changelog": "git log --pretty=format:\"* %s (%h)\" \"${from}...${to}\""
  },
  "github": {
    "release": true,
    "releaseName": "Slab Release v${version}",
    "draft": false,
    "assets": ["dist/slab.zip"],
    "changelog": "git log --pretty=format:\"* %s (%h)\" \"${from}...${to}\""
  },
  "npm": {
    "publish": false
  }
}
