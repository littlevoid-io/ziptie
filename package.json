{
  "name": "@littlevoid/ziptie",
  "version": "1.1.32",
  "description": "A modern, quirky, zero-dependency, and air-gap friendly Windows 11 kiosk and exhibit bootstrapping utility.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "ziptie.config.json",
    "ziptie.default.config.json",
    "ziptie.schema.json",
    "scripts",
    "setup.bat"
  ],
  "author": "littlevoid",
  "license": "MIT",
  "scripts": {
    "start": "node dist/index.js",
    "build": "node scripts/build-assets.js && bun build ./src/index.ts --target=node --outfile=dist/index.js",
    "package": "node scripts/build-assets.js && bun build --compile --target=node ./src/index.ts --outfile=dist/ziptie.exe && powershell -Command \"Compress-Archive -Path dist/ziptie.exe, scripts, ziptie.default.config.json, ziptie.schema.json, setup.bat -DestinationPath dist/ziptie.zip -Force\"",
    "sandbox": "npm run package && node test/launch-sandbox.js",
    "sandbox:local": "npm run package && node test/launch-sandbox.js --run-tests",
    "sandbox:remote": "node test/launch-sandbox-remote.js",
    "release": "node scripts/release.js",
    "test": "node scripts/build-assets.js && bun test test/cli.test.ts test/unit && bun run test:pester",
    "test:cli": "node scripts/build-assets.js && bun test test/cli.test.ts",
    "test:pester": "powershell -ExecutionPolicy Bypass -File test/run-tests.ps1",
    "test:pester5": "powershell -ExecutionPolicy Bypass -File test/run-pester5.ps1",
    "test:unit": "node scripts/build-assets.js && bun test test/unit"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "chalk": "^5.6.2",
    "deepmerge": "^4.3.1",
    "listr2": "^10.2.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/yargs": "^17.0.35",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0"
  }
}
