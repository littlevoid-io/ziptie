{
  "name": "@littlevoid/slab",
  "version": "1.0.1",
  "description": "A modern, quirky, zero-dependency, and air-gap friendly Windows 11 kiosk and exhibit bootstrapping utility.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "slab.config.json",
    "slab.default.config.json",
    "slab-schema.json",
    "scripts",
    "src/powershell",
    "setup.bat"
  ],
  "author": "littlevoid",
  "license": "MIT",
  "scripts": {
    "build": "bun build ./src/index.ts --target=node --outfile=dist/index.js",
    "package": "bun build --compile --target=node ./src/index.ts --outfile=dist/slab.exe",
    "sandbox": "npm run package && node test/launch-sandbox.js",
    "release": "release-it"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "chalk": "^5.6.2",
    "deepmerge": "^4.3.1",
    "listr2": "^10.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "release-it": "^20.0.1",
    "typescript": "^5.0.0"
  }
}
